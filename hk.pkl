amends "package://github.com/jdx/hk/releases/download/v1.44.0/hk@1.44.0#/Config.pkl"

hooks {
    ["pre-commit"] {
        steps {
            ["cargo-fmt"] {
                glob = List("*.rs")
                check = "cargo fmt --check"
                fix = "cargo fmt"
            }
        }
    }
    ["check"] {
        steps {
            ["cargo-fmt"] {
                glob = List("*.rs")
                check = "cargo fmt --check"
                fix = "cargo fmt"
            }
        }
    }
}
